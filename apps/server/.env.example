PORT=10001
HOST=0.0.0.0
CORS_ORIGINS=*

AUTH_USERNAME=admin
AUTH_PASSWORD=admin123
AUTH_USER_USERNAME=user
AUTH_USER_PASSWORD=user123
JWT_SECRET=gitcicd-dev-secret
JWT_EXPIRES_IN=7d

GIT_TEMP_DIR=.workspace

# 相对路径 = 相对 server 启动目录（打包后即 release/server/config/deploy-envs.json）
DEPLOY_ENV_FILE=config/deploy-envs.json

DEPLOY_WORKSPACE=.deploy-workspace
DEPLOY_BUILD_OUTPUT_DIR=html
DEPLOY_INSTALL_CMD=npm install
DEPLOY_BUILD_CMD=npm run build
